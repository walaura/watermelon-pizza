{
  "extends": [
    "@parcel/config-default"
  ],
  "reporters": [
    "...",
    "parcel-reporter-static-files-copy"
  ],
  "resolvers": [
    "...",
    "./parcel/resolver/pxmd.ts"
  ],
  "transformers": {
    "*.{md,pxmd}": [
      "...",
      "./parcel/transformer/intake.ts"
    ],
    "*.zip": [
      "...",
      "./parcel/transformer/zip.ts"
    ],
    "*.ts": [
      "./parcel/transformer/yummers.ts",
      "..."
    ]
  }
}
