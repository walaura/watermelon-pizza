{
  "extends": ["@parcel/config-default"],
  "reporters":  ["...", "parcel-reporter-static-files-copy"],
  "transformers": {
    "*.md": ["...", "./src-node/transformer/md.ts"],
    "*.magic": ["...", "./src-node/transformer/magic-pages.ts"],
    "*.html": ["...", "./src-node/transformer/toc.ts"]
  }
}