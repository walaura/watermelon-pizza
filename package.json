{
  "name": "watermelon-pizza",
  "version": "1.0.0",
  "description": "My personal website!!",
  "engines": {
    "node": ">=24.14.0"
  },
  "dependencies": {
    "@babel/core": "^7.7.5",
    "extract-zip": "^1.6.7",
    "fs-extra": "^6.0.1",
    "parcel": "^2.12.0",
    "parcel-reporter-static-files-copy": "^1.5.3",
    "prettier": "^1.19.1",
    "svgo": "^3.3.2"
  },
  "source": [
    "src/index.html",
    "src/words/index.html",
    "src/words/*.md"
