  "devDependencies": {
    "@parcel/plugin": "^2.16.4",
    "@types/node": "^25.6.0",
    "babel-plugin-transform-runtime": "^6.23.0",
    "babel-runtime": "^6.26.0",
    "marked": "^18.0.2"
  }
}
